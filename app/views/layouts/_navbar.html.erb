<header class="main-nav">
  <div class="nav-container">
    <div class="brand">
      <strong>BH Agendamentos</strong>
    </div>

    <nav class="actions">
      <%# Botões Principais %>
      <%= link_to '📅 Agendamentos', appointments_path,
          class: "nav-link #{'active' if current_page?(appointments_path) || current_page?(authenticated_root_path)}" %>

      <%= link_to '📊 Dashboard', dashboard_path,
          class: "nav-link #{'active' if current_page?(dashboard_path)}" %>

      <%# Espaçador para empurrar o Sair para a direita %>
      <span class="spacer"></span>

      <%= button_to 'Sair', destroy_user_session_path,
          method: :delete,
          class: 'nav-link logout',
          data: { turbo: false } %>
    </nav>
  </div>
</header>
