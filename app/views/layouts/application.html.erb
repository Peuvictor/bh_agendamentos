<!DOCTYPE html>
<html>
  <head>
    <title>BH Agendamentos</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 text-gray-800">

    <nav class="bg-blue-700 p-4 shadow-lg mb-6">
      <div class="max-w-7xl mx-auto flex justify-between items-center text-white">
        <%= link_to "Agenda BH 🗓️", root_path, class: "text-xl font-bold tracking-tight hover:text-blue-100 transition" %>

        <div class="space-x-4 flex items-center">
          <% if user_signed_in? %>
            <%= link_to "Meus Agendamentos", appointments_path, class: "hover:text-blue-200 text-sm font-medium" %>
            <%= link_to "Serviços", services_path, class: "hover:text-blue-200 text-sm font-medium" %>

            <span class="hidden sm:inline text-blue-200 text-xs ml-4">Oi, <%= current_user.email.split('@').first %>!</span>

            <%= button_to "Sair", destroy_user_session_path, method: :delete,
                class: "bg-blue-800 hover:bg-red-600 px-3 py-1 rounded text-xs transition font-semibold" %>
          <% else %>
            <%= link_to "Entrar", new_user_session_path, class: "hover:underline text-sm font-medium" %>
            <%= link_to "Criar Conta", new_user_registration_path, class: "bg-white text-blue-700 px-4 py-2 rounded-lg text-sm font-bold shadow-md" %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="container mx-auto px-5 max-w-7xl">
      <% if notice %>
        <div class="bg-blue-100 border-l-4 border-blue-500 text-blue-700 p-4 mb-6 rounded shadow-sm" role="alert">
          <p class="text-sm font-bold">Sucesso:</p>
          <p><%= notice %></p>
        </div>
      <% end %>

      <% if alert %>
        <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-6 rounded shadow-sm" role="alert">
          <p class="text-sm font-bold">Atenção:</p>
          <p><%= alert %></p>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
