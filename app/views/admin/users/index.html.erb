<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <%# CABEÇALHO %>
  <div class="flex items-center justify-between mb-8">
    <div>
      <%= link_to "← Voltar ao Dashboard", admin_dashboard_path, class: "text-sm font-bold text-gray-500 hover:text-blue-600 transition" %>
      <h1 class="text-3xl font-extrabold text-gray-900 mt-2">Gestão de Usuários</h1>
      <p class="text-gray-500">Administre as contas cadastradas na plataforma.</p>
    </div>
    <div class="bg-blue-900 text-white px-4 py-2 rounded-lg font-bold shadow-sm">
      Total: <%= @users.count %>
    </div>
  </div>

  <%# TABELA DE USUÁRIOS %>
  <div class="bg-white shadow-sm rounded-3xl border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-extrabold text-gray-500 uppercase tracking-wider">Usuário</th>
            <th class="px-6 py-4 text-left text-xs font-extrabold text-gray-500 uppercase tracking-wider">Contato</th>
            <th class="px-6 py-4 text-left text-xs font-extrabold text-gray-500 uppercase tracking-wider">Perfil / Role</th>
            <th class="px-6 py-4 text-right text-xs font-extrabold text-gray-500 uppercase tracking-wider">Ações</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-100">
          <% @users.each do |user| %>
            <tr class="hover:bg-gray-50 transition-colors">

              <%# IDENTIDADE %>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="h-10 w-10 flex-shrink-0">
                    <% if user.avatar.attached? %>
                      <%= image_tag user.avatar, class: "h-10 w-10 rounded-full object-cover border border-gray-200" %>
                    <% else %>
                      <div class="h-10 w-10 rounded-full bg-gray-200 flex items-center justify-center text-gray-500 font-bold">
                        <%= user.nome.present? ? user.nome[0] : "U" %>
                      </div>
                    <% end %>
                  </div>
                  <div class="ml-4">
                    <div class="text-sm font-bold text-gray-900"><%= user.nome %></div>
                    <div class="text-xs text-gray-400">ID: <%= user.id.to_s.first(8) %>...</div>
                  </div>
                </div>
              </td>

              <%# CONTATO %>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900 font-medium"><%= user.email %></div>
                <div class="text-xs text-gray-500"><%= user.telefone.present? ? user.telefone : "Sem telefone" %></div>
              </td>

              <%# ROLE (BADGES DINÂMICOS) %>
              <td class="px-6 py-4 whitespace-nowrap">
                <%
                  role_classes = case user.role
                                 when 'admin' then 'bg-purple-100 text-purple-700 border-purple-200'
                                 when 'provider' then 'bg-blue-100 text-blue-700 border-blue-200'
                                 else 'bg-gray-100 text-gray-600 border-gray-200'
                                 end
                %>
                <span class="px-3 py-1 inline-flex text-xs leading-5 font-bold rounded-full border <%= role_classes %> uppercase tracking-widest">
                  <%= user.role %>
                </span>
              </td>

              <%# AÇÕES %>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <% if user == current_user %>
                  <span class="text-xs text-gray-400 italic">Você (Admin)</span>
                <% else %>
                  <%= button_to admin_user_path(user),
                                method: :delete,
                                form: { data: { turbo_confirm: "⚠️ ATENÇÃO: Isso excluirá permanentemente o usuário #{user.nome} e todos os seus dados. Confirmar?" } },
                                class: "text-red-600 hover:text-red-900 font-bold bg-red-50 px-3 py-1 rounded-lg transition border border-red-100" do %>
                    Remover
                  <% end %>
                <% end %>
              </td>

            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
