<div class="max-w-7xl mx-auto mt-8 px-4 sm:px-6 lg:px-8">
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-extrabold text-gray-900">Painel de Controle Geral</h1>
      <p class="mt-1 text-sm text-gray-500">Visão panorâmica de todo o sistema BH Agendamentos.</p>
    </div>
    <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-bold bg-purple-100 text-purple-800 border border-purple-200">
      🛡️ Modo Administrador
    </span>
  </div>

  <div class="grid grid-cols-1 gap-5 sm:grid-cols-3 mb-10">
    <div class="bg-white overflow-hidden shadow-sm rounded-xl border border-gray-200 p-5 border-l-4 border-l-blue-500">
      <dt class="text-sm font-medium text-gray-500 truncate">Total de Clientes</dt>
      <dd class="mt-1 text-3xl font-extrabold text-gray-900"><%= @total_clientes %></dd>
    </div>

    <div class="bg-white overflow-hidden shadow-sm rounded-xl border border-gray-200 p-5 border-l-4 border-l-green-500">
      <dt class="text-sm font-medium text-gray-500 truncate">Prestadores Ativos</dt>
      <dd class="mt-1 text-3xl font-extrabold text-gray-900"><%= @total_prestadores %></dd>
    </div>

    <div class="bg-white overflow-hidden shadow-sm rounded-xl border border-gray-200 p-5 border-l-4 border-l-yellow-500">
      <dt class="text-sm font-medium text-gray-500 truncate">Agendamentos Realizados</dt>
      <dd class="mt-1 text-3xl font-extrabold text-gray-900"><%= @total_agendamentos %></dd>
    </div>
  </div>

  <div class="bg-white shadow-sm rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-200 bg-gray-50">
      <h3 class="text-lg leading-6 font-bold text-gray-900">Radar: Últimos 10 Agendamentos</h3>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-white">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">ID</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Cliente</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Serviço (Prestador)</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Data e Hora</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-bold text-gray-500 uppercase tracking-wider">Ações</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @agendamentos_recentes.each do |appointment| %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">#<%= appointment.id %></td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-bold text-gray-900"><%= appointment.client.nome %></div>
                <div class="text-xs text-gray-500"><%= appointment.client.email %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                  <%= appointment.service.nome %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 font-medium">
                <%= appointment.start_time.strftime("%d/%m/%Y às %H:%M") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= button_to "Cancelar à força", appointment_path(appointment), method: :delete, onclick: "return confirm('⚠️ Ação de Admin: Tem certeza que deseja cancelar este agendamento?');", class: "text-red-600 hover:text-red-900 font-bold" %>
              </td>
            </tr>
          <% end %>

          <% if @agendamentos_recentes.empty? %>
            <tr>
              <td colspan="5" class="px-6 py-10 text-center text-gray-500 font-medium">Nenhum agendamento registrado no sistema ainda.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
