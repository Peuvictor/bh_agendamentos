<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <%# 1. CABEÇALHO DO MODO DEUS %>
  <div class="md:flex md:items-center md:justify-between mb-10">
    <div class="min-w-0 flex-1">
      <h2 class="text-3xl font-extrabold text-gray-900 sm:text-4xl sm:tracking-tight">
        Painel de Controle
      </h2>
      <p class="mt-2 text-sm text-gray-500">Visão panorâmica da operação do BH Agendamentos.</p>
    </div>
    <div class="mt-4 flex md:ml-4 md:mt-0 gap-3">
      <%= link_to "Voltar para o Site", vitrine_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-lg shadow-sm text-sm font-bold text-gray-700 bg-white hover:bg-gray-50 transition" %>
    </div>
  </div>

  <%# 2. CARDS DE MÉTRICAS OPRACIONAIS %>
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-3 mb-12">

    <div class="bg-white overflow-hidden rounded-2xl shadow-sm border border-gray-100 p-6 flex items-center">
      <div class="p-4 bg-blue-50 rounded-xl mr-5">
        <span class="text-2xl">👥</span>
      </div>
      <div>
        <dt class="text-sm font-bold text-gray-500 uppercase tracking-wider">Clientes</dt>
        <dd class="mt-1 text-3xl font-black text-gray-900"><%= @total_clientes %></dd>
      </div>
    </div>

    <div class="bg-white overflow-hidden rounded-2xl shadow-sm border border-gray-100 p-6 flex items-center">
      <div class="p-4 bg-yellow-50 rounded-xl mr-5">
        <span class="text-2xl">💈</span>
      </div>
      <div>
        <dt class="text-sm font-bold text-gray-500 uppercase tracking-wider">Prestadores</dt>
        <dd class="mt-1 text-3xl font-black text-gray-900"><%= @total_prestadores %></dd>
      </div>
    </div>

    <div class="bg-white overflow-hidden rounded-2xl shadow-sm border border-gray-100 p-6 flex items-center">
      <div class="p-4 bg-green-50 rounded-xl mr-5">
        <span class="text-2xl">📅</span>
      </div>
      <div>
        <dt class="text-sm font-bold text-gray-500 uppercase tracking-wider">Total de Agendamentos</dt>
        <dd class="mt-1 text-3xl font-black text-gray-900"><%= @total_agendamentos %></dd>
      </div>
    </div>
  </div>
  <div class="flex gap-4 mb-10">
  <%= link_to "Gerenciar Usuários", admin_users_path, class: "bg-white border-2 border-blue-900 text-blue-900 px-6 py-3 rounded-2xl font-black hover:bg-blue-900 hover:text-white transition shadow-sm" %>
  <%= link_to "Gerenciar Serviços", admin_services_path, class: "bg-white border-2 border-blue-900 text-blue-900 px-6 py-3 rounded-2xl font-black hover:bg-blue-900 hover:text-white transition shadow-sm" %>
</div>

  <%# 3. FEED EM TEMPO REAL: ÚLTIMOS AGENDAMENTOS %>
  <div class="bg-white shadow-sm rounded-3xl border border-gray-100 overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-100 bg-gray-50">
      <h3 class="text-lg font-bold text-gray-900">Agendamentos Recentes (Top 10)</h3>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-white">
          <tr>
            <th scope="col" class="px-6 py-4 text-left text-xs font-extrabold text-gray-500 uppercase tracking-wider">Data do Serviço</th>
            <th scope="col" class="px-6 py-4 text-left text-xs font-extrabold text-gray-500 uppercase tracking-wider">Cliente</th>
            <th scope="col" class="px-6 py-4 text-left text-xs font-extrabold text-gray-500 uppercase tracking-wider">Serviço / Prestador</th>
            <th scope="col" class="px-6 py-4 text-left text-xs font-extrabold text-gray-500 uppercase tracking-wider">Status</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-100">
          <% if @agendamentos_recentes.any? %>
            <% @agendamentos_recentes.each do |appointment| %>
              <tr class="hover:bg-gray-50 transition-colors">

                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-bold text-gray-900"><%= appointment.start_time.strftime("%d/%m/%Y") %></div>
                  <div class="text-sm text-gray-500"><%= appointment.start_time.strftime("%H:%M") %></div>
                </td>

                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-bold text-gray-900"><%= appointment.client.nome %></div>
                  <div class="text-xs text-gray-500"><%= appointment.client.email %></div>
                </td>

                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 border border-blue-200">
                    <%= appointment.service.nome %>
                  </span>
                  <div class="text-xs text-gray-500 mt-1">Por: <%= appointment.service.user.nome %></div>
                </td>

                <td class="px-6 py-4 whitespace-nowrap">
                  <% badge_color = case appointment.status
                                   when 'confirmado' then 'bg-green-100 text-green-800'
                                   when 'cancelado' then 'bg-red-100 text-red-800'
                                   else 'bg-yellow-100 text-yellow-800'
                                   end %>
                  <span class="px-3 py-1 inline-flex text-xs leading-5 font-bold rounded-full <%= badge_color %> uppercase">
                    <%= appointment.status %>
                  </span>
                </td>

              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="4" class="px-6 py-10 text-center text-gray-500 text-sm">
                Nenhum agendamento registrado na plataforma ainda.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

</div>
