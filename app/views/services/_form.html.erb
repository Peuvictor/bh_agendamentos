<%= form_for(@service, html: { class: "space-y-6" }) do |f| %>

  <%# 1. NOME DO SERVIÇO %>
  <div>
    <%= f.label :nome, "Nome do Serviço", class: "block text-sm font-bold text-gray-700 mb-2" %>
    <%= f.text_field :nome, placeholder: "Ex: Corte Disfarçado, Banho e Tosa...",
        class: "block w-full px-4 py-3 rounded-2xl border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" %>
  </div>

  <%# 2. FOTO DE CAPA (BOX MAIS DISCRETO) %>
  <div class="border-2 border-dashed border-gray-200 rounded-2xl p-6 bg-gray-50 hover:bg-gray-100 transition-colors">
    <%= f.label :photo, class: "flex flex-col items-center cursor-pointer" do %>
      <span class="text-2xl mb-2">📸</span>
      <span class="text-sm font-bold text-blue-600">Escolher foto de capa</span>
      <span class="text-xs text-gray-400 mt-1">Recomendado: 800x400px (JPG ou PNG)</span>
      <%= f.file_field :photo, class: "hidden" %>
    <% end %>
  </div>

  <%# 3. DESCRIÇÃO %>
  <div>
    <%= f.label :descricao, "Descrição", class: "block text-sm font-bold text-gray-700 mb-2" %>
    <%= f.text_area :descricao, rows: 3, placeholder: "Explique os detalhes do serviço...",
        class: "block w-full px-4 py-3 rounded-2xl border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 transition-all" %>
  </div>

<%# 4. GRID: DURACAO + PRECO (SÍMBOLOS EXTERNOS) %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

    <%# DURAÇÃO %>
    <div class="flex flex-col">
      <%= f.label :duration, "Duração do Serviço", class: "block text-sm font-bold text-gray-700 mb-2" %>
      <div class="flex items-center">
        <%# Símbolo Fora %>
        <span class="text-2xl mr-3 bg-blue-50 w-12 h-12 flex items-center justify-center rounded-xl border border-blue-100 shadow-sm">
          ⏱️
        </span>
        <%# Input limpo sem padding exagerado %>
        <div class="flex-1 relative">
          <%= f.number_field :duration, step: 15,
              class: "block w-full px-4 py-3 rounded-xl border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all font-bold text-lg text-gray-900 shadow-sm" %>
          <span class="absolute right-4 inset-y-0 flex items-center text-xs font-bold text-gray-400 uppercase tracking-tighter">min</span>
        </div>
      </div>
    </div>

    <%# PREÇO %>
    <div class="flex flex-col">
      <%= f.label :preco, "Preço do Serviço", class: "block text-sm font-bold text-gray-700 mb-2" %>
      <div class="flex items-center">
        <%# Símbolo Fora %>
        <span class="text-lg font-black text-green-700 mr-3 bg-green-50 w-12 h-12 flex items-center justify-center rounded-xl border border-green-100 shadow-sm">
          R$
        </span>
        <%# Input limpo %>
        <%= f.number_field :preco, step: 0.01,
            class: "block flex-1 px-4 py-3 rounded-xl border-gray-200 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all font-black text-lg text-gray-900 shadow-sm" %>
      </div>
    </div>

  </div>

  </div>

 <%# 5. BOTÕES DE AÇÃO (COM RESPIRO E DIVISOR) %>
  <div class="mt-12 pt-8 border-t border-gray-100 flex flex-col sm:flex-row items-center gap-4">

    <%# Botão Cancelar - Mais discreto %>
    <%= link_to "Cancelar", services_path,
        class: "w-full sm:flex-1 text-center py-4 px-6 rounded-2xl border border-gray-200 text-gray-500 font-bold hover:bg-gray-50 transition-all order-2 sm:order-1" %>

    <%# Botão Salvar - Destaque Total (Cores do Cruzeiro) %>
    <%= f.submit "Salvar Serviço",
        class: "w-full sm:flex-1 py-4 px-6 rounded-2xl bg-blue-900 text-yellow-400 font-black shadow-xl hover:bg-black hover:scale-[1.02] active:scale-95 transition-all cursor-pointer order-1 sm:order-2" %>

  </div>
  
<% end %>
