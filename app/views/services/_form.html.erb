<%= form_with(model: service, class: "bg-white p-8 rounded-3xl shadow-sm border border-gray-100 space-y-8") do |form| %>

  <%# 🚨 BLOCO DE ERROS BLINDADO %>
  <% if service.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-600 p-5 rounded-r-xl">
      <div class="flex items-center">
        <svg class="h-6 w-6 text-red-600 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <h2 class="text-red-800 font-bold text-sm uppercase tracking-wide">
          <%= pluralize(service.errors.count, "erro") %> impediram de salvar:
        </h2>
      </div>
      <ul class="list-disc list-inside text-sm text-red-700 mt-3 ml-9 space-y-1">
        <% service.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# 📝 NOME DO SERVIÇO %>
  <div>
    <%= form.label :nome, "Nome do Serviço", class: "block text-sm font-bold text-gray-800 mb-2" %>
    <%= form.text_field :nome, placeholder: "Ex: Corte Disfarçado, Banho e Tosa...", class: "block w-full rounded-xl border-gray-200 bg-gray-50 px-4 py-3 text-gray-900 focus:bg-white focus:border-blue-600 focus:ring-2 focus:ring-blue-100 transition-all shadow-sm" %>
  </div>

  <%# 📸 UPLOAD DE CAPA %>
  <div class="border-2 border-dashed border-gray-200 rounded-2xl p-6 bg-gray-50 hover:bg-gray-100 transition-colors">
    <%= form.label :photo, "Foto de Capa do Serviço", class: "block text-sm font-bold text-gray-800 mb-3" %>
    <div class="flex items-center gap-4">
      <div class="h-12 w-12 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
      </div>
      <%= form.file_field :photo, class: "block w-full text-sm text-gray-600 file:mr-4 file:py-2.5 file:px-6 file:rounded-xl file:border-0 file:text-sm file:font-bold file:bg-blue-600 file:text-white hover:file:bg-black file:transition-all cursor-pointer" %>
    </div>
    <p class="text-xs text-gray-400 mt-3 ml-16">Recomendado: Imagem horizontal clara (JPG ou PNG).</p>
  </div>

  <%# 📄 DESCRIÇÃO %>
  <div>
    <%= form.label :descricao, "Descrição", class: "block text-sm font-bold text-gray-800 mb-2" %>
    <%= form.text_area :descricao, rows: 4, placeholder: "Explique os detalhes do serviço para o seu cliente...", class: "block w-full rounded-xl border-gray-200 bg-gray-50 px-4 py-3 text-gray-900 focus:bg-white focus:border-blue-600 focus:ring-2 focus:ring-blue-100 transition-all shadow-sm" %>
  </div>

  <%# ⏱️ TEMPO E PREÇO (GRID) %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 bg-blue-50/50 p-6 rounded-2xl border border-blue-100">
    <div>
      <%= form.label :duration, "Duração (Minutos)", class: "block text-sm font-bold text-gray-800 mb-2" %>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <span class="text-gray-400">⏱️</span>
        </div>
        <%= form.number_field :duration, step: 15, class: "block w-full rounded-xl border-gray-200 bg-white pl-12 pr-4 py-3 text-gray-900 focus:border-blue-600 focus:ring-2 focus:ring-blue-100 transition-all shadow-sm font-bold" %>
      </div>
    </div>

    <div>
      <%= form.label :preco, "Preço do Serviço", class: "block text-sm font-bold text-gray-800 mb-2" %>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <span class="text-green-600 font-bold">R$</span>
        </div>
        <%= form.number_field :preco, step: "0.01", class: "block w-full rounded-xl border-gray-200 bg-white pl-12 pr-4 py-3 text-gray-900 focus:border-blue-600 focus:ring-2 focus:ring-blue-100 transition-all shadow-sm font-bold" %>
      </div>
    </div>
  </div>

  <%# 🎯 BOTÕES DE AÇÃO %>
  <div class="pt-4 flex flex-col-reverse sm:flex-row justify-end gap-3 border-t border-gray-100 mt-8">
    <%= link_to "Cancelar", services_path, class: "w-full sm:w-auto text-center py-3 px-8 border border-gray-200 rounded-xl text-sm font-bold text-gray-600 bg-white hover:bg-gray-50 hover:text-red-600 transition-all shadow-sm" %>
    <%= form.submit "Salvar Serviço", class: "w-full sm:w-auto text-center py-3 px-8 rounded-xl text-sm font-extrabold text-yellow-400 bg-blue-800 hover:bg-black cursor-pointer transition-all shadow-md active:scale-95" %>
  </div>

<% end %>
