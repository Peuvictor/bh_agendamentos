<div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
  <h2 class="text-3xl font-extrabold text-gray-900 mb-8">Meu Painel de Desempenho</h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">

    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 border-l-4 border-l-green-500">
      <p class="text-sm font-medium text-gray-500 mb-1">Receita Garantida</p>
      <h3 class="text-3xl font-bold text-gray-900">
        <%= number_to_currency(@faturamento_realizado, unit: "R$ ", separator: ",", delimiter: ".") %>
      </h3>
      <p class="text-xs text-green-600 mt-2 font-semibold">Serviços concluídos</p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 border-l-4 border-l-blue-500">
      <p class="text-sm font-medium text-gray-500 mb-1">Receita Prevista</p>
      <h3 class="text-3xl font-bold text-gray-900">
        <%= number_to_currency(@faturamento_previsto, unit: "R$ ", separator: ",", delimiter: ".") %>
      </h3>
      <p class="text-xs text-blue-600 mt-2 font-semibold">Agendamentos futuros</p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 border-l-4 border-l-purple-500">
      <p class="text-sm font-medium text-gray-500 mb-1">Ticket Médio</p>
      <h3 class="text-3xl font-bold text-gray-900">
        <%= number_to_currency(@ticket_medio, unit: "R$ ", separator: ",", delimiter: ".") %>
      </h3>
      <p class="text-xs text-purple-600 mt-2 font-semibold">Por atendimento válido</p>
    </div>

  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

    <%# Card Faturamento %>
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
      <h3 class="text-lg font-bold text-gray-700 mb-6">Faturamento (Últimos 30 dias)</h3>
      <%= line_chart @faturamento_diario, prefix: "R$ ", thousands: ".", decimal: ",", colors: ["#2563eb"], empty: "Nenhum faturamento registrado." %>
    </div>

    <%# Card Volume %>
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
      <h3 class="text-lg font-bold text-gray-700 mb-6">Volume por Status</h3>
      <%= pie_chart @agendamentos_por_status, donut: true, colors: ["#10b981", "#f59e0b", "#ef4444"], empty: "Nenhum agendamento." %>
    </div>

  </div>
</div>
