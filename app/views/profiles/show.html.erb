<div class="max-w-3xl mx-auto mt-10 p-6">
  <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">

    <div class="h-32 bg-blue-900"></div>

    <div class="px-6 py-8 relative">
      <div class="absolute -top-16 left-6">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, class: "h-24 w-24 rounded-full object-cover border-4 border-white shadow-md bg-white" %>
        <% else %>
          <div class="h-24 w-24 rounded-full bg-gray-200 border-4 border-white shadow-md flex items-center justify-center text-gray-500 text-4xl">
            👤
          </div>
        <% end %>
      </div>

      <div class="text-right">
        <%= link_to "Editar Perfil", edit_user_registration_path, class: "inline-block bg-gray-100 hover:bg-gray-200 text-gray-800 font-bold py-2 px-4 rounded-lg shadow-sm transition" %>
      </div>

      <div class="mt-4">
        <h1 class="text-3xl font-extrabold text-gray-900"><%= @user.nome %></h1>
        <p class="text-gray-500 text-sm font-medium mt-1"><%= @user.email %></p>

        <span class="mt-2 inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-yellow-100 text-yellow-800">
          Prestador de Serviços
        </span>
      </div>

      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-gray-50 p-5 rounded-xl border border-gray-100">
          <h3 class="text-xs font-extrabold text-gray-400 uppercase tracking-wider mb-4">Contato & Local</h3>
          <div class="space-y-3 text-sm text-gray-700">
            <p class="flex items-center font-medium">
              <span class="mr-3 text-lg">📞</span>
              <%= @user.telefone.presence || "Nenhum telefone cadastrado" %>
            </p>
            <p class="flex items-center font-medium">
              <span class="mr-3 text-lg">📍</span>
              <%= @user.endereco.presence || "Nenhum endereço cadastrado" %>
            </p>
          </div>
        </div>

        <div class="bg-gray-50 p-5 rounded-xl border border-gray-100">
          <h3 class="text-xs font-extrabold text-gray-400 uppercase tracking-wider mb-4">Sobre Mim</h3>
          <p class="text-sm text-gray-600 leading-relaxed font-medium">
            <%= @user.bio.presence || "Você ainda não escreveu uma biografia. Clique em Editar Perfil para adicionar uma!" %>
          </p>
        </div>
      </div>

    </div>
  </div>
</div>
