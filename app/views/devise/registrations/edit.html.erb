<div class="min-h-[80vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
    <div class="text-center mb-8">
      <h2 class="text-3xl font-extrabold text-blue-900 italic">Editar Perfil ✏️</h2>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6", multipart: true }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :nome, "Nome Completo", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1"><%= f.text_field :nome, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm" %></div>
      </div>

      <div>
        <%= f.label :telefone, "Telefone", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1"><%= f.text_field :telefone, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm" %></div>
      </div>

      <div>
        <%= f.label :email, "E-mail", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1"><%= f.email_field :email, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm" %></div>
      </div>

      <% if current_user.provider? %>
        <div class="space-y-6 bg-blue-50 p-5 rounded-xl border border-blue-100">
          <h3 class="text-sm font-bold text-blue-800 border-b border-blue-200 pb-2">Área do Prestador</h3>

          <div>
            <%= f.label :avatar, "Foto Profissional", class: "block text-sm font-bold text-gray-700" %>
            <div class="mt-1"><%= f.file_field :avatar, class: "block w-full text-sm text-gray-500" %></div>
          </div>

          <div>
            <%= f.label :bio, "Biografia", class: "block text-sm font-bold text-gray-700" %>
            <div class="mt-1"><%= f.text_area :bio, rows: 3, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm" %></div>
          </div>

          <div>
            <%= f.label :endereco, "Endereço", class: "block text-sm font-bold text-gray-700" %>
            <div class="mt-1"><%= f.text_field :endereco, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm" %></div>
          </div>
        </div>
      <% end %>

      <div class="border-t border-gray-100 pt-6">
        <%= f.label :current_password, "Senha Atual (obrigatória para salvar)", class: "block text-sm font-bold text-gray-700" %>
        <%= f.password_field :current_password, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm mt-1" %>
      </div>

      <div class="pt-2">
        <%= f.submit "Atualizar Perfil", class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-yellow-400 bg-blue-800 hover:bg-black transition cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
