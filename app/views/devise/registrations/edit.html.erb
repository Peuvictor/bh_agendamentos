<div class="max-w-2xl mx-auto mt-10 mb-20">
  <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100">
    <h2 class="text-2xl font-extrabold text-gray-900 mb-6">Configurações do Perfil</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, multipart: true }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-6">

        <div>
          <%= f.label :avatar, "Foto de Perfil", class: "block text-sm font-bold text-gray-700 mb-2" %>
          <div class="flex items-center space-x-4">
            <% if resource.avatar.attached? %>
              <%= image_tag resource.avatar, class: "h-16 w-16 rounded-full object-cover border-2 border-blue-500 shadow-sm" %>
            <% else %>
              <div class="h-16 w-16 rounded-full bg-gray-200 flex items-center justify-center text-gray-500 text-2xl shadow-sm">
                👤
              </div>
            <% end %>
            <%= f.file_field :avatar, class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition" %>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :nome, class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :nome, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border bg-gray-50" %>
          </div>
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :telefone, class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :telefone, placeholder: "(31) 99999-9999", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
          </div>
          <div>
            <%= f.label :endereco, "Endereço Completo", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :endereco, placeholder: "Rua das Flores, 123 - Savassi, BH", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
          </div>
        </div>

        <div>
          <%= f.label :bio, "Biografia / Sobre você", class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_area :bio, rows: 3, placeholder: "Conte um pouco sobre sua experiência...", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
        </div>
      </div>

      <hr class="my-8 border-gray-200">

      <div class="space-y-6">
        <h3 class="text-lg font-bold text-gray-900">Segurança da Conta</h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :password, "Nova Senha", class: "block text-sm font-medium text-gray-700" %>
            <span class="text-xs text-gray-500">(deixe em branco se não quiser mudar)</span>
            <%= f.password_field :password, autocomplete: "new-password", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
          </div>
          <div>
            <%= f.label :password_confirmation, "Confirmar Nova Senha", class: "block text-sm font-medium text-gray-700" %>
            <br class="hidden md:block"> <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border" %>
          </div>
        </div>

        <div class="bg-blue-50 p-4 rounded-xl border border-blue-100 mt-6">
          <%= f.label :current_password, "Digite sua Senha Atual para salvar", class: "block text-sm font-extrabold text-blue-900" %>
          <span class="text-xs text-blue-700 mb-2 block">O sistema exige sua senha atual por segurança sempre que for alterar qualquer dado.</span>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "block w-full rounded-md border-blue-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm px-3 py-2 border bg-white" %>
        </div>
      </div>

      <div class="mt-8 flex items-center justify-end space-x-4">
        <%= link_to "Voltar para o Painel", dashboard_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
        <%= f.submit "Salvar Alterações", class: "cursor-pointer bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-lg shadow-md transition duration-200" %>
      </div>
    <% end %>
  </div>

  <div class="mt-8 p-6 bg-red-50 rounded-2xl border border-red-100 text-center">
    <h3 class="text-red-800 font-bold mb-2">Deseja encerrar suas atividades?</h3>
    <p class="text-sm text-red-600 mb-4">Esta ação apagará todos os seus dados e agendamentos.</p>
    <%= button_to "Cancelar minha conta", registration_path(resource_name), data: { confirm: "Tem certeza que deseja apagar sua conta?", turbo_confirm: "Tem certeza?" }, method: :delete, class: "inline-block bg-white text-red-600 font-bold py-2 px-4 border border-red-200 rounded-lg shadow-sm hover:bg-red-600 hover:text-white transition duration-200" %>
  </div>
</div>
