<div class="min-h-[80vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full bg-white p-8 rounded-2xl shadow-xl border border-gray-100">

    <div class="text-center mb-8">
      <h2 class="text-3xl font-extrabold text-blue-900 italic">Editar Perfil ✏️</h2>
      <p class="mt-2 text-sm text-gray-500">Mantenha os seus dados atualizados</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6", multipart: true }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :nome, "Nome Completo", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1">
          <%= f.text_field :nome, autofocus: true, autocomplete: "name",
              class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>
      </div>

      <div>
        <%= f.label :telefone, "Telefone / WhatsApp", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1">
          <%= f.text_field :telefone, placeholder: "(31) 90000-0000",
              class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>
      </div>

      <div>
        <%= f.label :email, "E-mail", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1">
          <%= f.email_field :email, autocomplete: "email",
              class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>
      </div>

      <div class="bg-gray-50 p-4 rounded-lg border border-gray-200 mt-2 mb-4">
        <label class="block text-sm font-bold text-gray-700 mb-3">Seu perfil no Agenda BH:</label>
        <div class="flex flex-col space-y-3 sm:flex-row sm:space-y-0 sm:space-x-6">
          <label class="flex items-center cursor-pointer">
            <%= f.radio_button :role, "client", id: "role_client", class: "h-5 w-5 text-blue-600 border-gray-300" %>
            <span class="ml-2 text-sm text-gray-800 font-medium">Sou Cliente</span>
          </label>
          <label class="flex items-center cursor-pointer">
            <%= f.radio_button :role, "provider", id: "role_provider", class: "h-5 w-5 text-blue-600 border-gray-300" %>
            <span class="ml-2 text-sm text-gray-800 font-medium">Sou Prestador</span>
          </label>
        </div>
      </div>

      <div id="campos-prestador" class="hidden space-y-6 bg-blue-50 p-5 rounded-xl border border-blue-100">
        <div>
          <%= f.label :avatar, "Alterar Foto de Perfil", class: "block text-sm font-bold text-gray-700" %>
          <div class="mt-1">
            <%= f.file_field :avatar, class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:bg-blue-100 file:text-blue-700 hover:file:bg-blue-200" %>
          </div>
        </div>

        <div>
          <%= f.label :bio, "Biografia / Resumo Profissional", class: "block text-sm font-bold text-gray-700" %>
          <div class="mt-1">
            <%= f.text_area :bio, rows: 3, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
          </div>
        </div>

        <div>
          <%= f.label :endereco, "Endereço (Bairro/BH)", class: "block text-sm font-bold text-gray-700" %>
          <div class="mt-1">
            <%= f.text_field :endereco, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
          </div>
        </div>
      </div>

      <div class="border-t border-gray-100 pt-6">
        <%= f.label :current_password, "Senha Atual", class: "block text-sm font-bold text-gray-700" %>
        <p class="text-xs text-gray-500 mb-2">(necessária para confirmar as alterações)</p>
        <%= f.password_field :current_password, autocomplete: "current-password",
            class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
      </div>

      <div class="pt-2">
        <%= f.submit "Atualizar Perfil", class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-yellow-400 bg-blue-800 hover:bg-black transition cursor-pointer" %>
      </div>
    <% end %>

    <div class="mt-6 text-center border-t border-gray-100 pt-4">
       <%= link_to "Voltar", :back, class: "text-sm text-gray-600 hover:underline" %>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const radioProvider = document.getElementById('role_provider');
    const radioClient = document.getElementById('role_client');
    const camposPrestador = document.getElementById('campos-prestador');

    function toggleFields() {
      if (radioProvider && radioProvider.checked) {
        camposPrestador.classList.remove('hidden');
      } else {
        camposPrestador.classList.add('hidden');
      }
    }

    // Executa ao carregar para verificar o estado atual (já que é edição)
    toggleFields();

    // Ouve mudanças nos botões
    [radioProvider, radioClient].forEach(radio => {
      if(radio) radio.addEventListener('change', toggleFields);
    });
  });
</script>
