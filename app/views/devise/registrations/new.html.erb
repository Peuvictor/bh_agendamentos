<div class="min-h-[80vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full bg-white p-8 rounded-2xl shadow-xl border border-gray-100">

    <div class="text-center mb-8">
      <h2 class="text-3xl font-extrabold text-blue-900 italic">Criar Conta 🚀</h2>
      <p class="mt-2 text-sm text-gray-500">Cadastre-se na plataforma</p>
    </div>

    <%# ⚠️ ATENÇÃO: Adicionado multipart: true para o upload de imagens funcionar %>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { multipart: true, class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <%# NOME %>
      <div>
        <%= f.label :nome, "Nome Completo", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1">
          <%= f.text_field :nome, autofocus: true, autocomplete: "name", class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>
      </div>

      <%# TELEFONE %>
      <div>
        <%= f.label :telefone, "Telefone / WhatsApp", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1">
          <%= f.text_field :telefone, placeholder: "(31) 90000-0000", class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>
      </div>

      <%# TIPO DE CONTA %>
      <div>
        <%= f.label :role, "O que você deseja fazer?", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1">
          <%# ⚠️ ATENÇÃO: Adicionado o id "user_role_select" para o JavaScript encontrar este campo %>
          <%= f.select :role,
              [['Quero agendar serviços (Cliente)', 'client'], ['Quero oferecer meus serviços (Prestador)', 'provider']],
              {},
              id: "user_role_select",
              class: "block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-white cursor-pointer" %>
        </div>
      </div>

      <%# 👇 BLOCO DINÂMICO DO PRESTADOR (Oculto por padrão) 👇 %>
      <div id="provider-extra-fields" class="hidden space-y-4 bg-blue-50 p-5 rounded-xl border border-blue-100">
        <h3 class="text-xs font-extrabold text-blue-900 border-b border-blue-200 pb-2 uppercase tracking-wide">💼 Complete sua Vitrine</h3>

        <div>
          <%= f.label :avatar, "Sua Foto ou Logo", class: "block text-sm font-bold text-gray-700 mb-1" %>
          <%= f.file_field :avatar, direct_upload: true, class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-bold file:bg-blue-600 file:text-white hover:file:bg-black transition cursor-pointer" %>
        </div>

        <div class="grid grid-cols-1 gap-4">
          <div>
            <%= f.label :bairro, "Bairro de Atendimento (BH)", class: "block text-sm font-bold text-gray-700 mb-1" %>
            <%= f.select :bairro,
                grouped_options_for_select(User::BAIRROS_POR_REGIAO),
                { include_blank: "Selecione o bairro..." },
                class: "block w-full rounded-xl border-gray-300 shadow-sm focus:border-blue-900 focus:ring-blue-900 py-2 sm:text-sm bg-white" %>
          </div>

          <%# 👇 NOVO: CAMPO DE ENDEREÇO 👇 %>
          <div>
            <%= f.label :endereco, "Logradouro (Rua, Nº)", class: "block text-sm font-bold text-gray-700 mb-1" %>
            <%= f.text_field :endereco, placeholder: "Ex: Rua Contorno, 1000", class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-white" %>
          </div>
        </div>
      </div>
      <%# E-MAIL %>
      <div>
        <%= f.label :email, "E-mail", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1">
          <%= f.email_field :email, autocomplete: "email", class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>
      </div>

      <%# SENHA %>
      <div>
        <%= f.label :password, "Senha", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1">
          <%= f.password_field :password, autocomplete: "new-password", class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>
      </div>

      <%# CONFIRMAÇÃO %>
      <div>
        <%= f.label :password_confirmation, "Confirmar Senha", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1">
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>
      </div>

      <div class="pt-2">
        <%= f.submit "Cadastrar", class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-yellow-400 bg-blue-800 hover:bg-black transition cursor-pointer" %>
      </div>
    <% end %>

    <div class="mt-6 text-center border-t border-gray-100 pt-4">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>

<%# 👇 SCRIPT BLINDADO PARA O RAILS 7 / TURBO 👇 %>
<script>
  // 1. Criamos a lógica como uma função global
  window.toggleProviderFields = function() {
    const roleSelect = document.getElementById("user_role_select");
    const providerFields = document.getElementById("provider-extra-fields");

    if (roleSelect && providerFields) {
      if (roleSelect.value === "provider") {
        providerFields.classList.remove("hidden");
      } else {
        providerFields.classList.add("hidden");
      }
    }
  };

  // 2. Event Delegation: Escutamos cliques no documento inteiro, mas só agimos se for no Select
  document.addEventListener("change", function(event) {
    if (event.target && event.target.id === "user_role_select") {
      window.toggleProviderFields();
    }
  });

  // 3. Cobrimos todas as rotas de carregamento da página possíveis
  document.addEventListener("turbo:load", window.toggleProviderFields);
  document.addEventListener("turbo:render", window.toggleProviderFields);
  window.addEventListener("DOMContentLoaded", window.toggleProviderFields);

  // 4. Execução forçada de fallback assim que o HTML for lido
  window.toggleProviderFields();
</script>
