<div class="min-h-[60vh] flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900 tracking-tight">
      Crie sua conta no BH Agendamentos
    </h2>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow-xl border border-gray-100 sm:rounded-2xl sm:px-10">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <%# CAMPO DE NOME: O herói que faltava para o seu banco de dados %>
        <div>
          <%= f.label :nome, "Seu Nome Completo", class: "block text-sm font-bold text-gray-700" %>
          <div class="mt-1">
            <%= f.text_field :nome, autofocus: true, placeholder: "Ex: Pedro Guimarães",
                class: "appearance-none block w-full px-3 py-3 border border-gray-200 rounded-xl shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-900 focus:border-blue-900 sm:text-sm bg-gray-50" %>
          </div>
        </div>

        <div>
          <%= f.label :email, class: "block text-sm font-bold text-gray-700" %>
          <div class="mt-1">
            <%= f.email_field :email, autocomplete: "email",
                class: "appearance-none block w-full px-3 py-3 border border-gray-200 rounded-xl shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-900 focus:border-blue-900 sm:text-sm bg-gray-50" %>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :password, "Senha", class: "block text-sm font-bold text-gray-700" %>
            <%= f.password_field :password, autocomplete: "new-password",
                class: "appearance-none block w-full px-3 py-3 border border-gray-200 rounded-xl shadow-sm focus:outline-none focus:ring-blue-900 focus:border-blue-900 sm:text-sm bg-gray-50" %>
          </div>

          <div>
            <%= f.label :password_confirmation, "Confirme a Senha", class: "block text-sm font-bold text-gray-700" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password",
                class: "appearance-none block w-full px-3 py-3 border border-gray-200 rounded-xl shadow-sm focus:outline-none focus:ring-blue-900 focus:border-blue-900 sm:text-sm bg-gray-50" %>
          </div>
        </div>

        <div>
          <%= f.submit "Criar minha conta",
              class: "w-full flex justify-center py-4 px-4 border border-transparent rounded-xl shadow-lg text-sm font-extrabold text-white bg-blue-900 hover:bg-black transition-all duration-300 transform hover:-translate-y-0.5 cursor-pointer" %>
        </div>
      <% end %>

      <div class="mt-6 text-center">
        <%= link_to "Já tenho uma conta? Entrar", new_session_path(resource_name), class: "text-sm font-medium text-blue-900 hover:text-blue-700" %>
      </div>
    </div>
  </div>
</div>
