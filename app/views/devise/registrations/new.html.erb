<div class="min-h-[80vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full bg-white p-8 rounded-2xl shadow-xl border border-gray-100">

    <div class="text-center mb-8">
      <h2 class="text-3xl font-extrabold text-blue-900 italic">Criar Conta 🚀</h2>
      <p class="mt-2 text-sm text-gray-500">Junte-se ao Agenda BH e gerencie seu tempo</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6", multipart: true }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :nome, "Nome Completo", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1">
          <%= f.text_field :nome, autofocus: true, autocomplete: "name",
              class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>
      </div>

      <div>
        <%= f.label :avatar, "Foto de Perfil", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1">
          <%= f.file_field :avatar, class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" %>
        </div>
      </div>

      <div class="bg-gray-50 p-4 rounded-lg border border-gray-200 mt-2 mb-4">
        <label class="block text-sm font-bold text-gray-700 mb-3">Como você quer usar o Agenda BH?</label>
        <div class="flex flex-col space-y-3 sm:flex-row sm:space-y-0 sm:space-x-6">

          <label class="flex items-center cursor-pointer">
            <%= f.radio_button :role, "client", checked: true, class: "h-5 w-5 text-blue-600 focus:ring-blue-500 border-gray-300" %>
            <span class="ml-2 text-sm text-gray-800 font-medium">Quero agendar horários</span>
          </label>

          <label class="flex items-center cursor-pointer">
            <%= f.radio_button :role, "provider", class: "h-5 w-5 text-blue-600 focus:ring-blue-500 border-gray-300" %>
            <span class="ml-2 text-sm text-gray-800 font-medium">Quero oferecer serviços</span>
          </label>

        </div>
      </div>

      <div>
        <%= f.label :bio, "Biografia / Resumo Profissional", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1">
          <%= f.text_area :bio, rows: 3, placeholder: "Conte um pouco sobre sua experiência...",
              class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>
      </div>

      <div>
        <%= f.label :endereco, "Endereço (Ex: Savassi, BH)", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1">
          <%= f.text_field :endereco, placeholder: "Rua, Número - Bairro, Cidade",
              class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>
      </div>

      <div>
        <%= f.label :email, "E-mail", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1">
          <%= f.email_field :email, autocomplete: "email",
              class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-bold text-gray-700" do %>
          Senha <% if @minimum_password_length %><span class="text-xs text-gray-500 font-normal">(mínimo <%= @minimum_password_length %> caracteres)</span><% end %>
        <% end %>
        <div class="mt-1">
          <%= f.password_field :password, autocomplete: "new-password",
              class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirmar Senha", class: "block text-sm font-bold text-gray-700" %>
        <div class="mt-1">
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>
      </div>

      <div class="pt-2">
        <%= f.submit "Cadastrar", class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-yellow-400 bg-blue-800 hover:bg-black focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition cursor-pointer" %>
      </div>
    <% end %>

    <div class="mt-6 text-center border-t border-gray-100 pt-4">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
