<div class="bg-white rounded-3xl p-8 mb-12 text-center shadow-sm border border-gray-100">
  <h1 class="text-4xl font-extrabold text-gray-900 mb-4">
    Agende seus serviços em <span class="text-blue-600">Belo Horizonte</span>
  </h1>
  <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
    Praticidade para marcar seus horários nas melhores barbearias, clínicas e estúdios da capital mineira.
  </p>
  <% unless user_signed_in? %>
    <div class="flex justify-center space-x-4">
      <%= link_to "Começar Agora", new_user_registration_path, class: "bg-blue-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-blue-700 transition shadow-lg" %>
    </div>
  <% end %>
</div>

<div class="mb-10">
  <h2 class="text-2xl font-bold text-gray-800 mb-6">Serviços Disponíveis</h2>

  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    <% @services.each do |service| %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 flex flex-col justify-between hover:shadow-md transition overflow-hidden">

        <%# CAPA DO SERVIÇO COM CLOUDINARY %>
        <% if service.photo.attached? %>
          <%= image_tag service.photo, class: "w-full h-48 object-cover" %>
        <% else %>
          <div class="w-full h-48 bg-gray-50 flex items-center justify-center border-b border-gray-100">
            <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
          </div>
        <% end %>

        <div class="p-6 flex-1 flex flex-col">
          <div class="flex items-center gap-3 mb-5 pb-4 border-b border-gray-50">
            <% if service.user.avatar&.attached? %>
              <%= image_tag service.user.avatar, class: "w-10 h-10 rounded-full object-cover border border-blue-100 shadow-sm" %>
            <% else %>
              <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white text-xs font-bold uppercase">
                <%= service.user.nome.present? ? service.user.nome[0] : "P" %>
              </div>
            <% end %>
            <div class="flex flex-col">
              <span class="text-[10px] uppercase tracking-wider text-gray-400 font-bold">Prestador</span>
              <span class="text-sm font-semibold text-gray-700 leading-none">
                <%= service.user.nome.present? ? service.user.nome : "Profissional" %>
              </span>
            </div>
          </div>

          <h3 class="text-xl font-bold text-gray-900 mb-2"><%= service.nome %></h3>
          <p class="text-gray-600 text-sm mb-4 line-clamp-2"><%= service.descricao %></p>

          <div class="flex items-center text-sm font-medium text-gray-500 mb-6 mt-auto">
            <span class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full mr-3">
              ⏱️ <%= service.duration || service.duracao_minutos || 30 %> min
            </span>
            <span class="text-green-600 font-bold">
              <%= number_to_currency(service.preco, unit: "R$ ", separator: ",", delimiter: ".") %>
            </span>
          </div>

          <%= link_to "Agendar agora", new_service_appointment_path(service), class: "w-full text-center bg-gray-900 text-white py-3 rounded-xl font-bold hover:bg-gray-800 transition" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
