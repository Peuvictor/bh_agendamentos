<%# BANNER PRINCIPAL %>
<div class="bg-gradient-to-b from-blue-50 to-white rounded-3xl p-8 md:p-16 mb-12 text-center shadow-sm border border-blue-100 relative overflow-hidden">

  <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4 relative z-10">
    Agende seus serviços em <span class="text-blue-600">Belo Horizonte</span>
  </h1>
  <p class="text-lg text-gray-600 mb-10 max-w-2xl mx-auto relative z-10">
    Praticidade para marcar seus horários nas melhores barbearias, clínicas e estúdios da capital mineira.
  </p>

  <%# 🔍 BARRA DE BUSCA %>
  <div class="max-w-4xl mx-auto relative z-10 w-full px-4">
    <%= form_with url: vitrine_path, method: :get, local: true, class: "flex flex-col md:flex-row gap-4 w-full" do |f| %>

      <%# CONTAINER DO INPUT %>
      <div class="relative flex-grow shadow-sm">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <svg class="h-6 w-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
        <%= f.text_field :query,
            value: params[:query],
            placeholder: "Barbearia, Corte, Estúdio...",
            class: "block w-full pl-12 pr-4 py-4 bg-white border border-gray-200 rounded-2xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-lg transition-all" %>
      </div>

      <%# CONTAINER DOS BOTÕES %>
      <div class="flex gap-2">
        <% if params[:query].present? %>
          <%= link_to "Limpar", vitrine_path, class: "flex items-center justify-center bg-white border border-gray-200 text-gray-500 hover:text-red-600 font-bold px-6 py-4 rounded-2xl transition shadow-sm hover:bg-gray-50" %>
        <% end %>

        <%= f.submit "Pesquisar", class: "bg-blue-800 text-yellow-400 font-extrabold py-4 px-10 rounded-2xl hover:bg-black transition cursor-pointer shadow-lg active:scale-95" %>
      </div>
    <% end %>
  </div>

  <%# CTA PARA PRESTADORES %>
  <% unless user_signed_in? %>
    <div class="mt-10 pt-6 relative z-10 flex justify-center gap-2 text-sm border-t border-blue-50 max-w-xs mx-auto">
      <span class="text-gray-500">É um profissional?</span>
      <%= link_to "Anuncie aqui", new_user_registration_path, class: "text-blue-600 font-bold hover:underline" %>
    </div>
  <% end %>
</div>

<%# LISTAGEM DE SERVIÇOS %>
<div class="mb-10 px-4">
  <div class="flex items-center justify-between mb-8">
    <% if params[:query].present? %>
      <h2 class="text-xl font-bold text-gray-800">Resultados para: <span class="text-blue-600">"<%= params[:query] %>"</span></h2>
    <% else %>
      <h2 class="text-2xl font-bold text-gray-800">Serviços Disponíveis</h2>
    <% end %>
  </div>

  <% if @services.any? %>
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      <% @services.each do |service| %>
        <div class="group bg-white rounded-3xl shadow-sm border border-gray-100 flex flex-col hover:shadow-xl transition-all duration-300 overflow-hidden">

          <%# CAPA %>
          <div class="relative h-52 overflow-hidden">
            <% if service.photo.attached? %>
              <%= image_tag service.photo, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
            <% else %>
              <div class="w-full h-full bg-gray-100 flex items-center justify-center italic text-gray-400">Sem foto</div>
            <% end %>
          </div>

          <div class="p-6 flex-1 flex flex-col">
            <%# PRESTADOR %>
            <div class="flex items-center gap-3 mb-4">
              <% if service.user.avatar&.attached? %>
                <%= image_tag service.user.avatar, class: "w-10 h-10 rounded-full object-cover ring-2 ring-blue-50" %>
              <% else %>
                <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold"><%= service.user.nome[0] %></div>
              <% end %>
              <span class="text-sm font-bold text-gray-700"><%= service.user.nome %></span>
            </div>

            <h3 class="text-xl font-bold text-gray-900 mb-1"><%= service.nome %></h3>

           <%# 👇 AVALIAÇÕES (AGORA COM LINK) %>
            <div class="mb-3">
              <% if service.reviews.any? %>
                <%= link_to service_reviews_path(service), class: "inline-flex items-center gap-1 hover:bg-gray-50 p-1 -ml-1 rounded-lg transition group" do %>
                  <span class="text-yellow-400 text-sm">⭐</span>
                  <span class="text-sm font-bold text-gray-700 group-hover:text-blue-600 transition">
                    <%= number_with_precision(service.reviews.average(:rating), precision: 1) %>
                  </span>
                  <span class="text-xs text-gray-400 group-hover:text-blue-600 ml-1 underline-offset-2 group-hover:underline transition">
                    (<%= service.reviews.count %> avaliações)
                  </span>
                <% end %>
              <% else %>
                <div class="flex items-center gap-1">
                  <span class="text-gray-300 text-sm">⭐</span>
                  <span class="text-xs text-gray-400 font-medium ml-1">Novo</span>
                </div>
              <% end %>
            </div>

            <p class="text-gray-500 text-sm mb-6 line-clamp-2"><%= service.descricao %></p>

            <div class="mt-auto flex items-center justify-between pt-4 border-t border-gray-50">
              <div class="flex flex-col">
                <span class="text-xs text-gray-400 font-bold uppercase tracking-widest">Valor</span>
                <span class="text-lg font-black text-green-600"><%= number_to_currency(service.preco, unit: "R$ ") %></span>
              </div>
              <%= link_to "Agendar", new_service_appointment_path(service), class: "bg-gray-900 text-white px-6 py-2.5 rounded-xl font-bold hover:bg-blue-600 transition" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%# EMPTY STATE (Lógica Corrigida) %>
    <div class="text-center py-20 bg-gray-50 rounded-3xl border-2 border-dashed border-gray-200">
      <span class="text-5xl">🔎</span>
      <h3 class="text-xl font-bold text-gray-900 mt-4">Nenhum serviço encontrado</h3>
      <% if params[:query].present? %>
        <p class="text-gray-500 mt-2">Não achamos nada com o termo "<strong><%= params[:query] %></strong>".</p>
        <%= link_to "Limpar busca", vitrine_path, class: "mt-6 inline-block bg-blue-600 text-white px-8 py-3 rounded-xl font-bold" %>
      <% else %>
        <p class="text-gray-500 mt-2">Ainda não há serviços cadastrados na plataforma.</p>
      <% end %>
    </div>
  <% end %>
</div>
