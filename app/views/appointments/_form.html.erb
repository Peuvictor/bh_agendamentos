<%= form_with(model: appointment, class: "space-y-6") do |f| %>
  <%# Alerta de Erros %>
  <% if appointment.errors.any? %>
    <div class="bg-red-50 p-4 rounded-xl border border-red-200 animate-pulse">
      <h2 class="text-red-800 font-bold text-sm mb-2">
        <%= pluralize(appointment.errors.count, "erro") %> impediram o agendamento:
      </h2>
      <ul class="list-disc list-inside text-red-700 text-xs space-y-1">
        <% appointment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :service_id, class: "block text-sm font-bold text-gray-700 mb-2" %>
    <%# Usando :nome porque é assim que está no seu Banco de Dados %>
    <%= f.collection_select :service_id, @services, :id, :nome, { prompt: "Selecione o serviço desejado..." },
        class: "w-full rounded-xl border-gray-200 bg-gray-50 shadow-sm focus:border-blue-900 focus:ring-blue-900 transition-all py-3" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :start_time, class: "block text-sm font-bold text-gray-700 mb-2" %>
      <%= f.datetime_field :start_time,
          class: "w-full rounded-xl border-gray-200 bg-gray-50 shadow-sm focus:border-blue-900 focus:ring-blue-900 transition-all py-3" %>
    </div>

    <div>
      <%= f.label :end_time, class: "block text-sm font-bold text-gray-700 mb-2" %>
      <%= f.datetime_field :end_time,
          class: "w-full rounded-xl border-gray-200 bg-gray-50 shadow-sm focus:border-blue-900 focus:ring-blue-900 transition-all py-3" %>
    </div>
  </div>

  <div class="pt-4">
    <%= f.submit "Confirmar Reserva",
        class: "w-full bg-blue-900 hover:bg-black text-white font-extrabold py-4 px-4 rounded-xl shadow-lg hover:shadow-blue-900/20 transition-all duration-300 transform hover:-translate-y-1 cursor-pointer" %>
  </div>
<% end %>
