<div style="background-color: red; color: white; padding: 20px; font-size: 30px; font-weight: bold; text-align: center;">
  ALERTA VERMELHO: O DOCKER ESTÁ LENDO O ARQUIVO NOVO!
</div>
<%= form_with(model: appointment, class: "space-y-6") do |f| %>

  <%# Alerta de Erros %>
  <% if appointment.errors.any? %>
    <div class="bg-red-50 p-4 rounded-xl border border-red-200 animate-pulse">
      <h2 class="text-red-800 font-bold text-sm mb-2">
        <%= pluralize(appointment.errors.count, "erro") %> impediram o agendamento:
      </h2>
      <ul class="list-disc list-inside text-red-700 text-xs space-y-1">
        <% appointment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
      <%= f.label :service_id, "Qual o serviço?", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.collection_select :service_id, @services, :id, :nome,
          { prompt: "Selecione um serviço...", selected: @appointment.service_id },
          { class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" } %>
    </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label for="appointment_date" class="block text-sm font-bold text-gray-700 mb-2">Data do Agendamento</label>
      <%= date_field_tag :appointment_date, params[:appointment_date], id: "appointment_date", min: Date.today,
          class: "w-full rounded-xl border-gray-200 bg-gray-50 shadow-sm focus:border-blue-900 focus:ring-blue-900 transition-all py-3" %>
    </div>

    <div>
      <label for="appointment_hour" class="block text-sm font-bold text-gray-700 mb-2">Horário</label>
      <%= select_tag :appointment_hour, options_for_select(@available_slots, params[:appointment_hour]), prompt: "Selecione a data primeiro...", id: "appointment_hour",
          class: "w-full rounded-xl border-gray-200 bg-gray-50 shadow-sm focus:border-blue-900 focus:ring-blue-900 transition-all py-3" %>
    </div>
  </div>

  <div class="pt-4">
    <%= f.submit "Confirmar Reserva",
        class: "w-full bg-blue-900 hover:bg-black text-white font-extrabold py-4 px-4 rounded-xl shadow-lg hover:shadow-blue-900/20 transition-all duration-300 transform hover:-translate-y-1 cursor-pointer" %>
  </div>
<% end %>

<div id="dados-agendamentos" data-ocupados="<%= @busy_slots.to_json %>" class="hidden"></div>

<script>
  function aplicarFiltroDeHorarios() {
    const dateInput = document.getElementById("appointment_date");
    const timeSelect = document.getElementById("appointment_hour");
    const serviceSelect = document.querySelector("select[name='appointment[service_id]']") || document.querySelector("select[name='service_id']");
    const dadosDiv = document.getElementById("dados-agendamentos");

    if (!dateInput || !timeSelect || !serviceSelect || !dadosDiv) return;

    const horariosOcupados = JSON.parse(dadosDiv.dataset.ocupados);

    function atualizarHorarios() {
      if (!dateInput.value || !serviceSelect.value) return;

      const dataEscolhida = dateInput.value;
      const servicoSelecionadoId = parseInt(serviceSelect.value, 10);
      const ocupadosDoPrestador = horariosOcupados[servicoSelecionadoId] || [];

      // O NOSSO ALARME BARULHENTO! (Vai pular na tela)
      alert(
        "🚨 RADAR DO JAVASCRIPT LIGADO!\n\n" +
        "1. ID do Serviço Selecionado: " + servicoSelecionadoId + "\n" +
        "2. Data Escolhida: " + dataEscolhida + "\n" +
        "3. Lista de Ocupados que o Rails mandou: " + JSON.stringify(ocupadosDoPrestador)
      );

      Array.from(timeSelect.options).forEach(option => {
        if (!option.value || option.value === "") return;

        const valorLimpo = option.value.substring(0, 5);
        const dataHoraCombo = `${dataEscolhida} ${valorLimpo}`;

        const jaOcupado = ocupadosDoPrestador.includes(dataHoraCombo);

        if (jaOcupado) {
          option.disabled = true;
          option.text = valorLimpo + " (Ocupado)";
          option.classList.remove("text-gray-400", "bg-gray-100");
          option.classList.add("text-red-500", "bg-red-50", "font-bold");
        } else {
          option.disabled = false;
          option.text = valorLimpo;
          option.classList.remove("text-gray-400", "bg-gray-100", "text-red-500", "bg-red-50", "font-bold");
        }
      });
    }

    dateInput.addEventListener("change", atualizarHorarios);
    serviceSelect.addEventListener("change", atualizarHorarios);
    atualizarHorarios();
  }

  document.addEventListener("turbo:load", aplicarFiltroDeHorarios);
  document.addEventListener("DOMContentLoaded", aplicarFiltroDeHorarios);
  aplicarFiltroDeHorarios();
</script>
