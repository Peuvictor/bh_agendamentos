<div class="max-w-2xl mx-auto mt-10 p-6 bg-white rounded-xl shadow-md border border-gray-100">
  <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">Novo Agendamento em BH</h1>

  <%= form_with(model: @appointment, local: true, class: "space-y-6") do |f| %>

    <% if @appointment.errors.any? %>
      <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 border border-red-200" role="alert">
        <p class="font-bold mb-1">Ops! Verifique os erros abaixo:</p>
        <ul class="list-disc list-inside">
          <% @appointment.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">1. Qual o profissional?</label>
      <select id="provider_select" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 bg-white">
        <option value="">Selecione um profissional...</option>
        <% User.provider.each do |provider| %>
          <option value="<%= provider.id %>"><%= provider.nome %></option>
        <% end %>
      </select>
    </div>

    <div class="mb-6">
      <%= f.label :service_id, "2. Qual o serviço?", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <select id="service_select" name="appointment[service_id]" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 bg-gray-100 cursor-not-allowed" disabled>
        <option value="">Primeiro selecione um profissional...</option>

        <% Service.all.each do |service| %>
          <option value="<%= service.id %>" data-provider-id="<%= service.user_id %>" style="display: none;" <%= 'selected' if (params.dig(:appointment, :service_id) || @appointment.service_id).to_s == service.id.to_s %>>
            <%= service.nome %>
          </option>
        <% end %>
      </select>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= label_tag :appointment_date, "Dia do Agendamento", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= date_field_tag :appointment_date, params[:appointment_date] || Date.today,
            min: Date.today,
            id: "appointment_date",
            class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= label_tag :appointment_hour, "Horário Disponível", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= select_tag :appointment_hour, options_for_select(@available_slots, params[:appointment_hour]),
            prompt: "Selecione a data primeiro...",
            id: "appointment_hour",
            class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
    </div>

    <p class="mt-1 text-xs text-gray-500 italic text-center">O tempo de término será calculado automaticamente, uai!</p>

    <div class="flex items-center justify-between pt-4 border-t border-gray-50">
      <%= link_to "Voltar", appointments_path, class: "text-sm text-gray-600 hover:text-gray-900 underline" %>
      <%= f.submit "Confirmar Agendamento",
          class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-lg transition duration-200 shadow-lg cursor-pointer" %>
    </div>
  <% end %>
</div>

<div id="dados-agendamentos" data-ocupados="<%= @busy_slots.to_json %>" class="hidden"></div>

<script>
  function iniciarScriptsDeAgendamento() {
    const providerSelect = document.getElementById("provider_select");
    const serviceSelect = document.getElementById("service_select");
    const dateInput = document.getElementById("appointment_date");
    const timeSelect = document.getElementById("appointment_hour");
    const dadosDiv = document.getElementById("dados-agendamentos");

    if (!dateInput || !timeSelect || !serviceSelect || !dadosDiv || !providerSelect) return;

    const horariosOcupados = JSON.parse(dadosDiv.dataset.ocupados);
// --- PARTE 1: A CASCATA (Profissional -> Serviço) COM DEBUG ---
    providerSelect.addEventListener("change", function() {
      const selectedProviderId = this.value;

      // RASTREADOR 1: Vai imprimir no Console qual ID você selecionou
      console.log("🕵️‍♂️ Profissional selecionado ID:", selectedProviderId);

      serviceSelect.value = "";
      serviceSelect.dispatchEvent(new Event('change'));

      if(selectedProviderId) {
        serviceSelect.disabled = false;
        serviceSelect.classList.remove("bg-gray-100", "cursor-not-allowed");
        serviceSelect.classList.add("bg-white");
        serviceSelect.options[0].text = "Agora selecione o serviço...";
      } else {
        serviceSelect.disabled = true;
        serviceSelect.classList.add("bg-gray-100", "cursor-not-allowed");
        serviceSelect.options[0].text = "Primeiro selecione um profissional...";
      }

      let encontrouAlgumServico = false;

      Array.from(serviceSelect.options).forEach(option => {
        if (option.value === "") return;

        // RASTREADOR 2: Mostra de quem é o serviço que o JS está olhando agora
        console.log("🔍 Lendo serviço:", option.text, "| ID do Dono:", option.dataset.providerId);

        if (option.dataset.providerId === selectedProviderId) {
          // Solução à prova de balas para navegadores (Mostra)
          option.style.display = "";
          option.hidden = false;
          option.disabled = false;
          encontrouAlgumServico = true;
        } else {
          // Solução à prova de balas para navegadores (Esconde)
          option.style.display = "none";
          option.hidden = true;
          option.disabled = true;
        }
      });

      // Se o cara não tem serviço nenhum cadastrado, avisa o cliente!
      if(selectedProviderId && !encontrouAlgumServico) {
        serviceSelect.options[0].text = "❌ Profissional sem serviços cadastrados";
        serviceSelect.disabled = true;
        serviceSelect.classList.add("bg-red-50", "text-red-600");
      } else {
        serviceSelect.classList.remove("bg-red-50", "text-red-600");
      }
    });

    // --- PARTE 2: SUA LÓGICA DE HORÁRIOS (Serviço + Data -> Hora) ---
    function atualizarHorarios() {
      if (!dateInput.value || !serviceSelect.value) {
        // Se apagou o serviço, reseta os horários para o padrão
        Array.from(timeSelect.options).forEach(option => {
           if (option.value !== "") {
             option.disabled = false;
             option.classList.remove("text-gray-400", "bg-gray-100", "text-red-600", "font-bold");
             option.text = option.value.substring(0, 5);
           }
        });
        return;
      }

      const dataEscolhida = dateInput.value;
      const servicoSelecionadoId = serviceSelect.value;
      const ocupadosDoPrestador = horariosOcupados[servicoSelecionadoId] || [];

      const [ano, mes, dia] = dataEscolhida.split('-');
      const dataFormatada = new Date(ano, mes - 1, dia);
      const hoje = new Date();
      hoje.setHours(0, 0, 0, 0);
      const isHoje = dataFormatada.getTime() === hoje.getTime();
      const horaAtual = new Date().getHours();
      const minutoAtual = new Date().getMinutes();

      Array.from(timeSelect.options).forEach(option => {
        if (!option.value || option.value === "") return;

        const valorLimpo = option.value.substring(0, 5);
        const partes = valorLimpo.split(':');
        const horaOpcao = parseInt(partes[0], 10);
        const minutoOpcao = parseInt(partes[1], 10);

        const dataHoraCombo = `${dataEscolhida} ${valorLimpo}`;
        const jaOcupado = ocupadosDoPrestador.includes(dataHoraCombo);
        const jaPassou = isHoje && (horaOpcao < horaAtual || (horaOpcao === horaAtual && minutoOpcao <= minutoAtual));

        if (jaPassou) {
          option.disabled = true;
          option.text = valorLimpo + " (Já passou)";
          option.classList.remove("text-red-600", "font-bold");
          option.classList.add("text-gray-400", "bg-gray-100");
        } else if (jaOcupado) {
          option.disabled = true;
          option.text = valorLimpo + " (Ocupado)";
          option.classList.remove("text-gray-400", "bg-gray-100");
          option.classList.add("text-red-600", "font-bold");
        } else {
          option.disabled = false;
          option.text = valorLimpo;
          option.classList.remove("text-gray-400", "bg-gray-100", "text-red-600", "font-bold");
        }
      });
    }

    dateInput.addEventListener("change", atualizarHorarios);
    serviceSelect.addEventListener("change", atualizarHorarios);

    atualizarHorarios();
  }

  // Registra os eventos para rodar no load e no turbo:load
  document.addEventListener("turbo:load", iniciarScriptsDeAgendamento);
  document.addEventListener("DOMContentLoaded", iniciarScriptsDeAgendamento);

  // Roda imediatamente
  iniciarScriptsDeAgendamento();
</script>
