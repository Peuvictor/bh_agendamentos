<div class="max-w-2xl mx-auto mt-10 p-6 bg-white rounded-xl shadow-md border border-gray-100">
  <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">Novo Agendamento em BH</h1>

  <%# A INJEÇÃO DE ROTA: Passamos o @service e o @appointment para o Rails montar a URL do POST %>
  <%= form_with(model: [@service, @appointment], local: true, class: "space-y-6") do |f| %>

    <% if @appointment.errors.any? %>
      <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 border border-red-200" role="alert">
        <p class="font-bold mb-1">Ops! Verifique os erros abaixo:</p>
        <ul class="list-disc list-inside">
          <% @appointment.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# DADOS ESTÁTICOS: O cliente já escolheu na Home, apenas mostramos para confirmar %>
    <div class="p-5 bg-gray-50 rounded-xl border border-gray-200 mb-6">
      <div class="mb-3">
        <p class="text-sm text-gray-500 font-medium">Profissional</p>
        <p class="font-bold text-gray-900 text-lg"><%= @service.user.nome %></p>
      </div>
      <div>
        <p class="text-sm text-gray-500 font-medium">Serviço Selecionado</p>
        <p class="font-bold text-blue-900 text-lg">
          <%= @service.nome %> — <%= number_to_currency(@service.preco, unit: "R$", separator: ",", delimiter: ".") %>
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= label_tag :appointment_date, "Dia do Agendamento", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= date_field_tag :appointment_date, params[:appointment_date] || Date.today,
            min: Date.today,
            id: "appointment_date",
            class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= label_tag :appointment_hour, "Horário Disponível", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= select_tag :appointment_hour, options_for_select(@available_slots, params[:appointment_hour]),
            prompt: "Selecione a data primeiro...",
            id: "appointment_hour",
            class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
    </div>

    <p class="mt-2 text-xs text-gray-500 italic text-center">O tempo de término será calculado automaticamente, uai!</p>

    <div class="flex items-center justify-between pt-6 border-t border-gray-100">
      <%= link_to "Voltar", root_path, class: "text-sm text-gray-600 hover:text-gray-900 font-medium underline" %>
      <%= f.submit "Confirmar Agendamento",
          class: "bg-blue-900 hover:bg-blue-800 text-white font-bold py-3 px-8 rounded-xl transition duration-200 shadow-md cursor-pointer" %>
    </div>
  <% end %>
</div>

<div id="dados-agendamentos" data-ocupados="<%= @busy_slots.to_json %>" class="hidden"></div>

<script>
  function iniciarScriptsDeAgendamento() {
    const dateInput = document.getElementById("appointment_date");
    const timeSelect = document.getElementById("appointment_hour");
    const dadosDiv = document.getElementById("dados-agendamentos");

    if (!dateInput || !timeSelect || !dadosDiv) return;

    // A refatoração do Controller nos entrega um Array simples agora
    const horariosOcupadosDoServico = JSON.parse(dadosDiv.dataset.ocupados || "[]");

    function atualizarHorarios() {
      if (!dateInput.value) {
        Array.from(timeSelect.options).forEach(option => {
           if (option.value !== "") {
             option.disabled = false;
             option.classList.remove("text-gray-400", "bg-gray-100", "text-red-600", "font-bold");
             option.text = option.value.substring(0, 5);
           }
        });
        return;
      }

      const dataEscolhida = dateInput.value;
      const [ano, mes, dia] = dataEscolhida.split('-');
      const dataFormatada = new Date(ano, mes - 1, dia);

      const hoje = new Date();
      hoje.setHours(0, 0, 0, 0);
      const isHoje = dataFormatada.getTime() === hoje.getTime();

      const horaAtual = new Date().getHours();
      const minutoAtual = new Date().getMinutes();

      Array.from(timeSelect.options).forEach(option => {
        if (!option.value || option.value === "") return;

        const valorLimpo = option.value.substring(0, 5);
        const partes = valorLimpo.split(':');
        const horaOpcao = parseInt(partes[0], 10);
        const minutoOpcao = parseInt(partes[1], 10);

        const dataHoraCombo = `${dataEscolhida} ${valorLimpo}`;

        // Verifica se a combinação data + hora bate com nosso array de ocupados
        const jaOcupado = horariosOcupadosDoServico.includes(dataHoraCombo);
        const jaPassou = isHoje && (horaOpcao < horaAtual || (horaOpcao === horaAtual && minutoOpcao <= minutoAtual));

        if (jaPassou) {
          option.disabled = true;
          option.text = valorLimpo + " (Já passou)";
          option.classList.remove("text-red-600", "font-bold");
          option.classList.add("text-gray-400", "bg-gray-100");
        } else if (jaOcupado) {
          option.disabled = true;
          option.text = valorLimpo + " (Ocupado)";
          option.classList.remove("text-gray-400", "bg-gray-100");
          option.classList.add("text-red-600", "font-bold");
        } else {
          option.disabled = false;
          option.text = valorLimpo;
          option.classList.remove("text-gray-400", "bg-gray-100", "text-red-600", "font-bold");
        }
      });
    }

    dateInput.addEventListener("change", atualizarHorarios);
    atualizarHorarios();
  }

  document.addEventListener("turbo:load", iniciarScriptsDeAgendamento);
  document.addEventListener("DOMContentLoaded", iniciarScriptsDeAgendamento);
  iniciarScriptsDeAgendamento();
</script>
