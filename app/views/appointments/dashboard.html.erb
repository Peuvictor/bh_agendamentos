<div class="max-w-5xl mx-auto mt-10 p-6">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-800">Minha Agenda 📅</h1>
      <p class="text-gray-600 mt-1">Acompanhe os próximos clientes agendados com você.</p>
    </div>
    <%= link_to "Novo Serviço", new_service_path, class: "bg-black hover:bg-gray-800 text-white font-bold py-2 px-4 rounded-lg shadow transition" %>
  </div>

  <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden">
    <% if @my_appointments.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-extrabold text-gray-500 uppercase tracking-wider">Data e Hora</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-extrabold text-gray-500 uppercase tracking-wider">Serviço</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-extrabold text-gray-500 uppercase tracking-wider">Contato do Cliente</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-extrabold text-gray-500 uppercase tracking-wider">Status</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-extrabold text-gray-500 uppercase tracking-wider">Ações</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @my_appointments.each do |appointment| %>
            <%# Muda a cor da linha se estiver cancelado para dar destaque visual %>
            <tr class="hover:bg-gray-50 transition-colors <%= 'opacity-60 bg-gray-50' if appointment.cancelado? %>">

              <%# DATA E HORA %>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-bold <%= appointment.cancelado? ? 'line-through text-gray-400' : 'text-gray-900' %>">
                  <%= appointment.start_time.strftime("%d/%m/%Y") %>
                </div>
                <div class="text-sm text-gray-500 flex items-center mt-1">
                  <svg class="w-4 h-4 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  <%= appointment.start_time.strftime("%H:%M") %>
                </div>
              </td>

              <%# SERVIÇO %>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-3 py-1 inline-flex text-xs leading-5 font-bold rounded-full bg-blue-100 text-blue-800 border border-blue-200">
                  <%= appointment.service.nome %>
                </span>
              </td>

              <%# CONTATO (BOTÃO DO WHATSAPP) %>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-bold text-gray-900"><%= appointment.client.nome %></div>

                <% if appointment.client.telefone.present? %>
                  <%= link_to "https://wa.me/55#{appointment.client.telefone.gsub(/\D/, '')}?text=Olá #{appointment.client.nome.split.first}, aqui é do #{appointment.service.user.nome}. Confirmo seu horário das #{appointment.start_time.strftime('%H:%M')}?",
                      target: "_blank",
                      class: "inline-flex items-center gap-1.5 mt-1 bg-green-50 text-green-700 px-2 py-1 rounded-md font-bold text-xs hover:bg-green-100 transition shadow-sm" do %>
                    <span>💬 WhatsApp</span>
                  <% end %>
                <% else %>
                  <div class="text-xs text-gray-500 mt-1"><%= appointment.client.email %></div>
                <% end %>
              </td>

              <%# STATUS DINÂMICO %>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <% if appointment.confirmado? %>
                  <span class="text-green-600 font-bold flex items-center">
                    <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse mr-2"></span>
                    Confirmado
                  </span>
                <% elsif appointment.cancelado? %>
                  <span class="text-red-500 font-bold flex items-center">
                    <span class="w-2 h-2 bg-red-500 rounded-full mr-2"></span>
                    Cancelado
                  </span>
                <% else %>
                  <span class="text-yellow-600 font-bold flex items-center">
                    <span class="w-2 h-2 bg-yellow-500 rounded-full mr-2"></span>
                    Pendente
                  </span>
                <% end %>
              </td>

              <%# AÇÕES (CONFIRMAR E CANCELAR) %>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <div class="flex flex-col items-end gap-2">
                  <%# Mostra botão de confirmar se estiver pendente %>
                  <% if appointment.pendente? %>
                    <%= button_to "Confirmar", update_status_appointment_path(appointment, status: :confirmado),
                        method: :patch,
                        class: "text-green-600 hover:bg-green-50 border border-green-600 px-3 py-1 rounded-md font-bold text-xs w-24 text-center transition" %>
                  <% end %>

                  <%# Mostra botão de cancelar se NÃO estiver cancelado %>
                  <% unless appointment.cancelado? %>
                    <%= button_to "Cancelar", update_status_appointment_path(appointment, status: :cancelado),
                        method: :patch,
                        data: { turbo_confirm: "⚠️ Tem certeza que deseja cancelar este agendamento, uai?" },
                        class: "text-red-600 hover:bg-red-50 border border-red-600 px-3 py-1 rounded-md font-bold text-xs w-24 text-center transition" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-12 text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-100 mb-4">
          <span class="text-2xl">😴</span>
        </div>
        <h3 class="text-lg font-bold text-gray-900">Agenda Vazia</h3>
        <p class="mt-2 text-sm text-gray-500">Você ainda não tem clientes marcados para os próximos dias.</p>
      </div>
    <% end %>
  </div>
</div>
