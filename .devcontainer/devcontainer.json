{
  "name": "BH Agendamentos - Pedro Victor",
  "image": "mcr.microsoft.com/devcontainers/ruby:3.3",
  "features": {
    "ghcr.io/devcontainers/features/postgres:1": {
      "version": "15"
    },
    "ghcr.io/devcontainers/features/redis-server:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "shopify.ruby-lsp",
        "GitHub.copilot",
        "vscjava.vscode-java-pack"
      ]
    }
  },
  "onCreateCommand": "bundle install",
  "postCreateCommand": "bin/rails db:prepare",
  "remoteUser": "vscode"
}
